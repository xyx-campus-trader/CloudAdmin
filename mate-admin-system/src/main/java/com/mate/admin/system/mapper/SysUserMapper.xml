<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mate.admin.system.mapper.SysUserMapper">

    <!-- 用户分页查询：JOIN 部门表
         索引：idx_dept_status (dept_id, status, create_time)
         EXPLAIN: type=ref, key=idx_dept_status, rows=千级 -->
    <select id="selectUserPage" resultType="com.mate.admin.system.entity.SysUser">
        SELECT u.*
        FROM sys_user u
        WHERE u.is_deleted = 0
        <if test="deptId != null">
            AND u.dept_id = #{deptId}
        </if>
        <if test="status != null">
            AND u.status = #{status}
        </if>
        ORDER BY u.create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="selectUserCount" resultType="int">
        SELECT COUNT(*)
        FROM sys_user u
        WHERE u.is_deleted = 0
        <if test="deptId != null">
            AND u.dept_id = #{deptId}
        </if>
        <if test="status != null">
            AND u.status = #{status}
        </if>
    </select>
</mapper>
